{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://ssc-ai.github.io/satsim/schema/v1/types/UnitInterval.json",
    "title": "Unit Interval",
    "description": "A number in the closed interval [0.0, 1.0], or a generated number expected to resolve to that range.",
    "anyOf": [
        {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
        },
        { "$ref": "GeneratedNumber.json" }
    ]
}
