{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://ssc-ai.github.io/satsim/schema/v1/types/PositiveFloat.json",
    "title": "Positive Float",
    "description": "A number greater than 0.0, or a generated number expected to resolve to a positive value.",
    "anyOf": [
        {
            "type": "number",
            "exclusiveMinimum": 0.0
        },
        { "$ref": "GeneratedNumber.json" }
    ]
}
